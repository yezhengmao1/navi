# tmux-web-bridge — nginx reverse-proxy template.
#
# Covers:
#   - HTTPS termination (fill in your cert paths)
#   - WebSocket upgrade for /ws (browser) and /agent (agent)
#   - Long-lived idle tolerance so the heartbeat/30s idle pane doesn't
#     get killed by nginx's default 60s proxy_read_timeout.
#
# Replace `bridge.example.com` with your host and adjust the upstream.

# Map the Connection header: only set `upgrade` when the client actually
# sent one — otherwise stay on keep-alive. Required for WS proxying.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream tmux_bridge {
    server 127.0.0.1:8787;
    # If you run the container on another host, swap in its addr:port.
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name bridge.example.com;
    # Plain-HTTP → HTTPS; comment this block out if you terminate TLS elsewhere.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name bridge.example.com;

    ssl_certificate     /etc/letsencrypt/live/bridge.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bridge.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Upload cap is irrelevant for this app (no file uploads) — keep small.
    client_max_body_size 1m;

    # ── WebSocket endpoints ────────────────────────────────────
    # Both /ws (browser) and /agent (agent) need Upgrade handling.
    # We carve them out so the long read timeout + buffer-off doesn't
    # apply to plain HTTP traffic like /app.js.
    location = /ws {
        proxy_pass         http://tmux_bridge;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection $connection_upgrade;
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Server sends a ping every 30s; give plenty of slack above that
        # so a transient stall doesn't tear the socket down.
        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;
        proxy_buffering     off;   # stream frames as they arrive
    }

    location = /agent {
        proxy_pass         http://tmux_bridge;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection $connection_upgrade;
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;
        proxy_buffering     off;
    }

    # ── Everything else (HTML, JS, static) ─────────────────────
    location / {
        proxy_pass         http://tmux_bridge;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        # Keep defaults: buffering on, ~60s read timeout is fine for /,/app.js
    }
}
